{
  "manifest_version": 3,
  "name": "NEXUS",
  "version": "1.0.0",
  "description": "Transform your new tab into a productivity hub with elegant time display, smart shortcuts, and focus tools",
  "author": "mosaddiq",
  "homepage_url": "https://github.com/hellomosaddiq/nexus-new-tab",

  "chrome_url_overrides": {
    "newtab": "src/pages/newtab/index.html"
  },

  "permissions": [
    "bookmarks",
    "topSites",
    "sessions",
    "storage",
    "history",
    "tabs"
  ],

  "host_permissions": [
    "https://*/*"
  ],

  "background": {
    "service_worker": "src/background/background.js"
  },

  "action": {
    "default_title": "NEXUS - New Tab Hub",
    "default_icon": {
      "16": "assets/icons/nexus-16.png",
      "32": "assets/icons/nexus-32.png",
      "48": "assets/icons/nexus-48.png",
      "128": "assets/icons/nexus-128.png"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'self'; img-src 'self' data: https: http:; connect-src 'self' https: http:; default-src 'self';"
  },

  "icons": {
    "16": "assets/icons/nexus-16.png",
    "32": "assets/icons/nexus-32.png",
    "48": "assets/icons/nexus-48.png",
    "128": "assets/icons/nexus-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/*.png",
        "assets/icons/*.svg",
        "assets/icons/favicon.ico"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
